// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum StyleKeyword {
  CASUAL
  STREET
  MINIMAL
  LOVELY
  FORMAL
}

enum UserRole {
  USER
  ADMIN
}

enum ReportReason {
  SPAM
  ABUSE
  INAPPROPRIATE
  ETC
}

enum ReportTargetType {
  POST
  USER
}

enum DetectionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model User {
  id                String              @id @default(uuid())
  loginId           String              @unique
  email             String              @unique
  password          String
  nickname          String
  isEmailVerified   Boolean             @default(false)

  styleKeyword      StyleKeyword
  height            Int
  weight            Int
  bio               String?
  profileImage      String?

  role              UserRole            @default(USER)
  isDeleted         Boolean             @default(false)
  lastLoginAt       DateTime?

  refreshTokens     RefreshToken[]
  posts             Post[]

  followers         Follow[]            @relation("UserToFollowers")
  followings        Follow[]            @relation("UserToFollowings")

  likes             Like[]
  bookmarks         Bookmark[]
  
  reportsMade       Report[]            @relation("Reporter")
  reportsReceived   Report[]            @relation("ReportedUser")

  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  emailVerifications EmailVerification[]

  @@index([loginId])
  @@index([nickname])
  @@index([email])
}

model EmailVerification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  code      String
  sendCount Int      @default(1)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model RefreshToken {
  id              String          @id @default(uuid())
  token           String          @unique
  userId          String
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  userAgent       String?
  ipAddress       String?
  expiresAt       DateTime

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([userId])
}

model Follow {
  id              String          @id @default(uuid())
  followerId      String
  followingId     String

  follower        User            @relation("UserToFollowings", fields: [followerId], references: [id], onDelete: Cascade)
  following       User            @relation("UserToFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  createdAt       DateTime        @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Post {
  id                String              @id @default(uuid())
  title             String
  description       String
  authorId          String
  author            User                @relation(fields: [authorId], references: [id], onDelete: Cascade)

  images            PostImage[]
  hashtags          Hashtag[]
  detectedProducts  DetectedProduct[]
  likes             Like[]
  bookmarks         Bookmark[]
  reports           Report[]

  viewCount         Int                 @default(0)
  likeCount         Int                 @default(0)
  bookmarkCount     Int                 @default(0)
  
  trendScore        Float               @default(0)
  detectionStatus   DetectionStatus     @default(COMPLETED)

  isDeleted         Boolean             @default(false)

  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([authorId])
  @@index([createdAt])
  @@index([viewCount])
  @@index([likeCount])
  @@index([trendScore])
}

model PostImage {
  id              String          @id @default(uuid())
  imageUrl        String
  order           Int             @default(0)
  postId          String
  post            Post            @relation(fields: [postId], references: [id], onDelete: Cascade)

  createdAt       DateTime        @default(now())
  @@index([postId])
}

model Hashtag {
  id              String          @id @default(uuid())
  name            String          @unique
  posts           Post[]
}

model DetectedProduct {
  id              String          @id @default(uuid())
  name            String?
  brand           String?
  purchaseUrl     String?
  imageUrl        String?

  positionX       Float?
  positionY       Float?
  width           Float?
  height          Float?

  category        String?
  price           Int?
  confidence      Float?
  isEdited        Boolean         @default(false)

  postId          String
  post            Post            @relation(fields: [postId], references: [id], onDelete: Cascade)

  productId       String?
  product         Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([postId])
}

model Like {
  id              String          @id @default(uuid())
  userId          String
  postId          String
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  post            Post            @relation(fields: [postId], references: [id], onDelete: Cascade)

  createdAt       DateTime        @default(now())

  @@unique([userId, postId])
  @@index([userId])
  @@index([postId])
}

model Bookmark {
  id              String          @id @default(uuid())
  userId          String
  postId          String
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  post            Post            @relation(fields: [postId], references: [id], onDelete: Cascade)

  createdAt       DateTime        @default(now())

  @@unique([userId, postId])
  @@index([userId])
  @@index([postId])
}

model Report {
  id              String          @id @default(uuid())
  reason          ReportReason
  description     String?
  targetType      ReportTargetType    @default(POST)
  
  reporterId      String
  reporter        User                @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)

  postId          String?
  post            Post?               @relation(fields: [postId], references: [id], onDelete: Cascade)

  reportedUserId  String?
  reportedUser    User?               @relation("ReportedUser", fields: [reportedUserId], references: [id], onDelete: Cascade)

  createdAt       DateTime            @default(now())

  @@index([reporterId])
  @@index([postId])
  @@index([reportedUserId])
}

model FashionSearch {
  id              String          @id @default(uuid())
  originalImage   String
  items           FashionItem[]
  createdAt       DateTime        @default(now())
}

model FashionItem {
  id              String          @id @default(uuid())
  type            String
  croppedImage    String
  brand           String?
  brandConfidence Float?
  searchQuery     String?
  products        FashionProduct[]
  searchId        String
  search          FashionSearch   @relation(fields: [searchId], references: [id], onDelete: Cascade)
  createdAt       DateTime        @default(now())

  @@index([searchId])
}

model FashionProduct {
  id              String          @id @default(uuid())
  title           String
  brand           String?
  price           Int?
  image           String?
  link            String?
  itemId          String
  item            FashionItem     @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
}

model Product {
  id              String            @id @default(uuid())
  externalId      String            @unique
  source          String
  name            String
  brand           String?
  brandName       String?
  thumbnailUrl    String?
  productUrl      String?
  price           Int?
  reviewCount     Int?
  reviewScore     Float?
  category        String?
  gender          String?
  isDeleted       Boolean           @default(false)

  images          ProductImage[]
  embeddings      ProductEmbedding[]
  detectedProducts DetectedProduct[]

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([externalId])
  @@index([category])
}

model ProductImage {
  id              String            @id @default(uuid())
  productId       String
  product         Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  imageUrl        String
  imageType       String?
  order           Int               @default(0)

  embeddings      ProductEmbedding[]

  createdAt       DateTime          @default(now())

  @@index([productId])
}

model ProductEmbedding {
  id              String            @id @default(uuid())
  productId       String
  product         Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  productImageId  String
  productImage    ProductImage      @relation(fields: [productImageId], references: [id], onDelete: Cascade)
  vectorId        String            @unique
  modelName       String
  dimension       Int

  createdAt       DateTime          @default(now())

  @@index([productId])
  @@index([productImageId])
}